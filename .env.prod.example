# Root .env.prod — used by: docker compose -f docker-compose.prod.yml up (VPS)
# Copy to .env.prod on your VPS and fill in real values
# NEVER commit this file

# Docker Hub
DOCKER_USER=yourdockerhubuser
TAG=latest

# Domain
DOMAIN=yourdomain.com

# MongoDB (with auth)
MONGO_USER=vlxd
MONGO_PASSWORD=change_me_to_a_strong_password

# Backend secrets
JWT_SECRET=change_me_to_a_random_string

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSL email (for Let's Encrypt)
SSL_EMAIL=admin@yourdomain.com
