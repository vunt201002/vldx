{
  "name": "vlxd-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts",
    "seed:blocks": "ts-node-dev --transpile-only src/scripts/seedBlocks.ts",
    "seed:product-pages": "ts-node-dev --transpile-only src/scripts/seedProductPages.ts",
    "seed:update-navbars": "ts-node-dev --transpile-only src/scripts/seedUpdateNavbars.ts",
    "migrate": "ts-node-dev --transpile-only src/migrations/run-migrations.ts",
    "migrate:theme": "ts-node-dev --transpile-only src/migrations/001-create-default-theme.ts",
    "migrate:products": "ts-node-dev --transpile-only src/migrations/002-migrate-products.ts"
  },
  "dependencies": {
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
