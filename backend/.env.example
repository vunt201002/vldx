NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/vlxd
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# JWT Configuration (generate a strong random secret for production)
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars_change_this_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email Configuration (SMTP - for Gmail: enable 2FA and create App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
EMAIL_FROM=noreply@vlxd.com

# Cloudinary (https://console.cloudinary.com → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
