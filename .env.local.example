# Root .env.local — used by: docker compose up (local dev with Docker)
# Copy to .env.local and fill in values

# Public URLs (used for CORS)
FRONTEND_URL=http://localhost
ADMIN_URL=http://localhost:8080

# Port mapping on host
FRONTEND_PORT=80
ADMIN_PORT=8080

# API URL for Next.js rewrites (internal Docker network)
NEXT_PUBLIC_API_URL=http://backend:5000/api

# Admin build-time env
VITE_API_URL=/api
VITE_STOREFRONT_URL=http://localhost

# MongoDB (no auth for local dev)
MONGODB_URI=mongodb://mongodb:27017/vlxd

# Backend secrets
JWT_SECRET=local_dev_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
